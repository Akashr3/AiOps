import sqlite3

def login_vulnerable(username, password):
    conn = sqlite3.connect("users.db")
    cursor = conn.cursor()

    # ⚠️ Directly concatenating user input into the query
    query = "SELECT * FROM users WHERE username = '" + username + "' AND password = '" + password + "';"

    print(f"Query executed: {query}")  # So your friend can see what runs
    cursor.execute(query)
    result = cursor.fetchone()
    conn.close()

    return "✅ Login successful!" if result else "❌ Login failed."

# --- Normal use ---
print(login_vulnerable("alice", "mypassword"))
# Query: SELECT * FROM users WHERE username = 'alice' AND password = 'mypassword';

# --- SQL Injection attack ---
print(login_vulnerable("' OR '1'='1", "' OR '1'='1"))
# Query: SELECT * FROM users WHERE username = '' OR '1'='1' AND password = '' OR '1'='1';
# '1'='1' is always TRUE → attacker bypasses login without knowing any credentials!




import sqlite3

def login_secure(username, password):
    conn = sqlite3.connect("users.db")
    cursor = conn.cursor()

    # ✅ User input is passed as parameters, NEVER concatenated into the query string
    query = "SELECT * FROM users WHERE username = ? AND password = ?;"

    print(f"Query template: {query}")
    cursor.execute(query, (username, password))  # DB treats inputs as pure data, not SQL
    result = cursor.fetchone()
    conn.close()

    return "✅ Login successful!" if result else "❌ Login failed."

# --- Normal use ---
print(login_secure("alice", "mypassword"))

# --- Same SQL Injection attempt → completely neutralised ---
print(login_secure("' OR '1'='1", "' OR '1'='1"))
# The DB looks for a user literally named  ' OR '1'='1  → finds nobody → login fails ✅
